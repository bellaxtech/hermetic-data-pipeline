# Airflow
AIRFLOW_UID=501
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_FERNET_KEY=CHANGE_ME

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=source_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spark & Iceberg
SPARK_MASTER=spark://spark-master:7077
ICEBERG_WAREHOUSE=file:///tmp/iceberg_warehouse
ICEBERG_NAMESPACE=analytics

# Webhooks (optional)
SLACK_WEBHOOK_URL=

# SSL / Proxy (corporate network)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,.local

# Logging
LOG_LEVEL=INFO
